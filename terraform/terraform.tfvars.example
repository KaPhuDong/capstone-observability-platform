# Copy this file to terraform.tfvars and customize

aws_region  = "ap-southeast-1"
environment = "dev"

cluster_name    = "capstone-obs-cluster"
cluster_version = "1.30"

vpc_cidr = "10.0.0.0/16"

node_group_desired_size = 3
node_group_min_size     = 2
node_group_max_size     = 5
node_instance_types     = ["t3.xlarge"]

enable_argocd = true

# IAM users/roles cần quyền kubectl admin vào cluster
# Thêm ARN của bạn vào đây để tránh tạo Access Entry thủ công sau khi apply
admin_iam_arns = [
  # "arn:aws:iam::ACCOUNT_ID:user/admin",
  # "arn:aws:iam::ACCOUNT_ID:role/DevOpsRole",
]
